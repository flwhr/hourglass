# Hourglass configuration — copy to `.env` and fill in.
#   cp .env.example .env
# Real environment variables take precedence over values in .env.

# --- Required ---

# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# SQLite database file path (created on first run)
DATABASE_URL=hourglass.db

# --- Optional ---

# uma.moe API key (only needed for protected endpoints; leave blank otherwise)
UMAMOE_API_KEY=

# Shared uma.moe rate limiter: requests/minute and burst size
UMAMOE_RATE_PER_MIN=20
UMAMOE_RATE_BURST=5

# Daily poll time in UTC (HH:MM). uma.moe publishes ~15:10 UTC.
POLL_TIME_UTC=15:20

# Discord role id allowed to manage clubs (besides server Administrators).
# Leave blank to require Administrator for management commands.
MANAGER_ROLE_ID=

# Promotion / relegation marker emojis
EMOJI_PROMOTE=⬆️
EMOJI_RELEGATE=⬇️
